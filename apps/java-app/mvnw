set -e

# Resolve the project base directory
APP_BASE_FOLDER=$(cd "$(dirname "$0")" && pwd)
MAVEN_PROJECTBASEDIR="$APP_BASE_FOLDER"

# Resolve JAVA_CMD
if [ -n "$JAVA_HOME" ]; then
  JAVA_CMD="$JAVA_HOME/bin/java"
elif command -v java >/dev/null 2>&1; then
  JAVA_CMD="java"
else
  echo "Error: JAVA_HOME is not set and java is not found in PATH." >&2
  exit 1
fi

WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

# Download maven-wrapper.jar if not present
if [ ! -f "$WRAPPER_JAR" ]; then
  WRAPPER_URL=$(grep 'wrapperUrl' "$WRAPPER_PROPERTIES" | sed 's/wrapperUrl=//')
  echo "Downloading Maven Wrapper from $WRAPPER_URL ..."
  mkdir -p "$(dirname "$WRAPPER_JAR")"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL -o "$WRAPPER_JAR" "$WRAPPER_URL"
  elif command -v wget >/dev/null 2>&1; then
    wget -q -O "$WRAPPER_JAR" "$WRAPPER_URL"
  else
    echo "Error: Neither curl nor wget found. Cannot download Maven Wrapper." >&2
    exit 1
  fi
fi

exec "$JAVA_CMD" \
  -classpath "$WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  org.apache.maven.wrapper.MavenWrapperMain "$@"
