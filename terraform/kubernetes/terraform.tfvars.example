# Copy this file to terraform.tfvars and adjust values for your environment.
# terraform.tfvars は .gitignore 対象です。

# --- General ----------------------------------------------------------------
# 全リソース名・タグ・Datadog service/env の先頭に付く識別子。
# パートナー様ごとに一意な名前に変更してご利用ください（小文字英数字とハイフンのみ）。
# name_prefix = "pov"

# AWS リージョン
# region = "ap-northeast-1"

# --- Network ----------------------------------------------------------------
# vpc_cidr             = "10.0.0.0/16"
# public_subnet_cidrs  = ["10.0.101.0/24", "10.0.102.0/24"]
# private_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24"]

# EKS API サーバーのパブリックエンドポイントへのアクセスを許可する送信元 CIDR。
# デフォルトは 0.0.0.0/0（全開放）。必要に応じてオフィス IP 等に絞ってください。
# allowed_ip = ["1.2.3.4/32"]

# --- EKS --------------------------------------------------------------------
# eks_cluster_version = "1.31"
# node_instance_type  = "t3.medium"
# node_volume_size    = 30
# node_desired_size   = 2
# node_min_size       = 1
# node_max_size       = 3

# --- RDS --------------------------------------------------------------------
# db_instance_class    = "db.t4g.micro"
# db_engine_version    = "17.10"
# db_allocated_storage = 20
