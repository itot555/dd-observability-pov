# Terraform state
*.tfstate
*.tfstate.*

# Terraform working directory
.terraform/
# NOTE: .terraform.lock.hcl は HashiCorp 公式推奨に従いコミット対象とします
# （全環境で同じ provider バージョンを使用して再現性を確保）

# Terraform plan files
*.tfplan

# Variable files (may contain sensitive or environment-specific values)
terraform.tfvars

# locals.tf contains PII (name, email) and environment-specific tags
terraform/locals.tf
terraform/single-host/locals.tf
terraform/kubernetes/locals.tf

# Steering files (may contain PII, instance IDs, IP addresses)
# Only .steering/public/ is tracked
.steering/*.md

# SSH key files generated by keypair.tf
keys/

# Credentials and secrets
*.pem
*.key
*.p12
*.pfx
*_rsa
*_rsa.pub
*_ed25519
*_ed25519.pub
credentials
credentials.json
*.credentials

# Environment variable files
.env
.env.*
!.env.example

# AWS credential files
.aws/credentials
aws_credentials*

# macOS
.DS_Store

# Maven build output
apps/java-app/target/
apps/kubernetes/java-app/target/

# Python virtualenv & bytecode
__pycache__/
*.pyc
venv/
.venv/

# IDE
.idea/
.vscode/

# Logs
*.log
